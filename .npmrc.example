# Copy this file to `.npmrc` and supply a token to install the private
# @testsigmainc/ui-atoms package from GitHub Packages.
#
#   cp .npmrc.example .npmrc
#   # then either paste a GitHub PAT with read:packages in place of the env var,
#   # or export NODE_AUTH_TOKEN=<token> before running `npm install`.
#
# The real .npmrc is gitignored so the token is never committed.

save-exact=true
@testsigmainc:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
